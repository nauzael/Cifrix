# ================================================================
# CIFRIX - ENVIRONMENT VARIABLES CONFIGURATION
# ================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local or .env files to version control!
# ================================================================

# ========================================
# SUPABASE CONFIGURATION (REQUIRED)
# ========================================
# Get these from your Supabase project settings
# Dashboard: https://app.supabase.com/project/[PROJECT_ID]/settings/api

# Your Supabase project URL
# Example: https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase public anon key (safe to expose)
# Used for client-side authentication
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ⚠️ IMPORTANT: Only use in local development scripts
# Never expose this key publicly or commit to git
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Local PostgreSQL connection string (optional, for local dev)
# Format: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/cifrix

# ========================================
# OFFLINE CONFIGURATION
# ========================================
# Enable offline-first mode (IndexedDB sync)
VITE_OFFLINE_MODE=true

# Sync interval in milliseconds (default: 180000 = 3 minutes)
VITE_SYNC_INTERVAL_MS=180000

# ========================================
# APPLICATION CONFIGURATION
# ========================================
# Application metadata
VITE_APP_NAME=Cifrix
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=development

# ========================================
# DEVELOPMENT & DEBUGGING
# ========================================
# Enable debug mode (verbose logging)
# Set to 'true' for development, 'false' for production
VITE_DEBUG_MODE=false

# Log level: 'debug', 'info', 'warn', 'error'
VITE_LOG_LEVEL=info

# ========================================
# FEATURE FLAGS
# ========================================
# Enable/disable specific features
# Set to 'true' or 'false'

# Offline sync functionality
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_SYNC=true

# Accounting module
VITE_ENABLE_ACCOUNTING=true

# Invoice/Invoicing module
VITE_ENABLE_INVOICING=true

# Income tax declaration (Declaración de Renta)
VITE_ENABLE_RENTA=true

# External income reports (Reportes Exógenos)
VITE_ENABLE_EXOGENOS=true

# Church/Diezmos module
VITE_ENABLE_DIEZMOS=true

# Advanced reporting features
VITE_ENABLE_ADVANCED_REPORTS=true

# ========================================
# DIAN CONFIGURATION (Colombia)
# ========================================
# DIAN = Dirección de Impuestos y Aduanas Nacionales
# Only required if using electronic invoice submission

# DIAN environment: 'development' or 'production'
VITE_DIAN_ENV=development

# DIAN API endpoint
# Development: https://api-habilitacion.dian.gov.co
# Production: https://api.dian.gov.co
VITE_DIAN_API_URL=https://api-habilitacion.dian.gov.co

# DIAN credentials (if needed)
# DIAN_USERNAME=your_dian_username
# DIAN_PASSWORD=your_dian_password

# ========================================
# API CONFIGURATION
# ========================================
# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# Number of retry attempts for failed requests
VITE_API_RETRY_ATTEMPTS=3

# ========================================
# BUILD CONFIGURATION
# ========================================
# These are typically set by your build tool, but can be overridden here

# Node environment: 'development', 'production', 'test'
NODE_ENV=development

# ================================================================
# SETUP INSTRUCTIONS
# ================================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your actual values in .env.local
# 3. Never commit .env.local to version control
# 4. For CI/CD, use GitHub Secrets or your platform's secret manager
# 5. Test your configuration with: npm run dev
# ================================================================

# ========================================
# NOTES
# ========================================
# SECURITY: Never commit this file with real values
# Use .env.local for local development
# Use .env.production for production builds
# All VITE_* variables are exposed to client-side code
