# ================================================================
# CIFRIX - COMPREHENSIVE GITIGNORE CONFIGURATION
# ================================================================

# ======================
# DEPENDENCIES & BUILDS
# ======================
node_modules/
pnpm-lock.yaml
npm-shrinkwrap.json
yarn.lock
dist/
dist-ssr/
dev-dist/
build/
*.local

# ======================
# ENVIRONMENT VARIABLES
# ======================
# Never commit sensitive environment variables
.env
.env.local
.env.*.local
.env.production.local
.env.development.local
.env.test.local

# ======================
# LOGS & DEBUGGING
# ======================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
ts_errors.txt
debug.log

# ======================
# LOCAL DATABASE & STORAGE
# ======================
.lcm/
lcm.db
lcm.db-shm
lcm.db-wal
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ======================
# DEVELOPMENT SCRIPTS
# ======================
# Debug and test scripts that may contain sensitive data
scripts/debug*.js
scripts/test*.js
scripts/test_*.js
scripts/*.txt
scripts/output_*.txt
inspect_xlsx.cjs
test-sync.ts

# ======================
# AGENT & DOCUMENTATION CONFIG
# ======================
# AI Agent configuration and internal documentation
.agent/
.agents/
.documentacion/
.trae/
.lcm/

# ======================
# IDE & EDITOR CONFIG
# ======================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.idea_modules/
*.iml
*.iws
*.ipr
.sublime-workspace
.sublime-project
.code-workspace

# ======================
# OS-SPECIFIC FILES
# ======================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
.AppleDouble
.LSOverride

# ======================
# EDITOR TEMP FILES
# ======================
*.suo
*.ntvs*
*.njsproj
*.sln
*.sln.iml
*.sw?
*.swo
*.swp
*~
.#*

# ======================
# PYTHON ENVIRONMENTS
# ======================
__pycache__/
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
env/
venv/
ENV/
build-env/

# ======================
# NODE & NPM ARTIFACTS
# ======================
npm-debug.log
yarn-debug.log
yarn-error.log
lerna-debug.log

# ======================
# BUILD ARTIFACTS
# ======================
.cache/
.tmp/
temp/
build-temp/
dist-temp/
coverage/
.nyc_output/

# ======================
# SOURCE MAPS (keep in dev, exclude from prod)
# ======================
*.map
!dist/**/*.map

# ======================
# VERCEL DEPLOYMENT
# ======================
.vercel/project.json
.vercelignore

# ======================
# CERTIFICATES & SSL
# ======================
*.pem
*.key
*.cert
*.crt

# ======================
# MISC
# ======================
.cache
.parcel-cache
.next
out/
# ======================
.vscode-test/
.vscode/settings.json
.vscode/launch.json
.vercel
