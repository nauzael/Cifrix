          "name": "Mejorar .gitignore",
          "description": "Crear .gitignore comprensivo que excluya archivos sensibles, builds, y artifacts",
          "files": [".gitignore"],
          "status": "PENDING",
          "priority": "CRITICAL",
          "details": {
            "add_patterns": [
              "# Local database",
              ".lcm/",
              "lcm.db*",
              "",
              "# Development scripts",
              "scripts/debug*.js",
              "scripts/test*.js",
              "scripts/*.txt",
              "",
              "# Build artifacts",
              "dev-dist/",
              "__pycache__/",
              "*.pyc",
              "",
              "# Agent configuration",
              ".agent/",
              ".agents/",
              ".documentacion/",
              ".trae/",
              "",
              "# Vercel sensitive",
              ".vercel/project.json",
              ".vercelignore",
              "",
              "# IDE/Editor",
              ".idea/",
              "*.sublime-*",
              "",
              "# OS files",
              "Thumbs.db",
              "*.swp",
              "*.swo"
            ]
          }
        },
        {
          "id": "cleanup-git-history",
          "name": "Remover archivos del historial de git",
          "description": "Usar git rm --cached para remover archivos sensibles sin eliminarlos localmente",
          "commands": [
            "git rm --cached -r .lcm/",
            "git rm --cached .agent/ .agents/ .documentacion/ .trae/",
            "git rm --cached scripts/debug*.js scripts/test*.js scripts/*.txt",
            "git rm --cached ts_errors.txt",
            "git rm --cached dev-dist/",
            "git commit -m 'chore: remove sensitive and build files from git tracking'"
          ],
          "status": "PENDING",
          "priority": "HIGH",
          "note": "Ejecutar después de actualizar .gitignore"
        },
